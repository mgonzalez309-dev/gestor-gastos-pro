# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Variables separadas (documentativas)
DB_HOST=localhost
DB_PORT=5432
DB_USER=tu_usuario
DB_PASSWORD=tu_contrasena
DB_NAME=gestor_gastos

# Cadena usada por Prisma/NestJS
DATABASE_URL=postgresql://tu_usuario:tu_contrasena@localhost:5432/gestor_gastos

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
PORT=4500
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=tu_secreto_jwt
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------------
# OCR / AI
# -----------------------------------------------------------------------------
GOOGLE_VISION_API_KEY=tu_api_key_google_vision_opcional
RECEIPT_AI_API_KEY=tu_api_key_modelo
RECEIPT_AI_MODEL=gpt-4o-mini
RECEIPT_AI_API_URL=https://api.openai.com/v1/chat/completions
