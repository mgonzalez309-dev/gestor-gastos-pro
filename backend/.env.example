# ─────────────────────────────────────────────
# Base de datos PostgreSQL
# ─────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL="postgresql://postgres:password@localhost:5432/gastos_db"

# ─────────────────────────────────────────────
# JWT (JSON Web Token)
# ─────────────────────────────────────────────
# Genera un secreto fuerte para producción, ej: openssl rand -hex 32
JWT_SECRET="tu_secreto_jwt_super_seguro_cambialo_en_produccion"
JWT_EXPIRES_IN="24h"

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─────────────────────────────────────────────
# CORS – URL del frontend
# ─────────────────────────────────────────────
FRONTEND_URL="http://localhost:5500"

# ─────────────────────────────────────────────
# Subida de archivos
# ─────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ─────────────────────────────────────────────
# OCR (Opcional – Google Vision API)
# Si se provee, se usa en lugar de Tesseract.js local
# ─────────────────────────────────────────────
# GOOGLE_VISION_API_KEY="tu_api_key_de_google_vision"

# ─────────────────────────────────────────────
# Receipt AI Agent (LLM para estructurar OCR)
# ─────────────────────────────────────────────
RECEIPT_AI_API_KEY="tu_api_key_del_modelo"
RECEIPT_AI_MODEL="gpt-4o-mini"
# Opcional: endpoint compatible con OpenAI Chat Completions
# RECEIPT_AI_API_URL="https://api.openai.com/v1/chat/completions"
